+                <span>{item.text}</span>
+              </div>
+            ))}
+          </div>
+          <div className="flex flex-col gap-3">
+            <Link href="/academy"
+              className="block w-full py-3 rounded-xl font-bold text-white text-center transition-opacity hover:opacity-90"
