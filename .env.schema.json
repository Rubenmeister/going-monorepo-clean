{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Going Platform - Environment Schema",
  "description": "Validates required environment variables for all services",
  "type": "object",
  "required": [
    "NODE_ENV",
    "PORT"
  ],
  "properties": {
    "NODE_ENV": {
      "type": "string",
      "enum": ["development", "staging", "production"],
      "description": "Application environment"
    },
    "PORT": {
      "type": "integer",
      "minimum": 1024,
      "maximum": 65535,
      "description": "Service port"
    },
    "CORS_ORIGINS": {
      "type": "string",
      "description": "Comma-separated list of allowed CORS origins",
      "default": "http://localhost:3000,http://localhost:3001"
    },
    "JWT_SECRET": {
      "type": "string",
      "minLength": 32,
      "description": "JWT signing secret (min 32 chars)"
    },
    "JWT_EXPIRES_IN": {
      "type": "string",
      "default": "24h",
      "description": "JWT expiration time"
    },
    "MONGODB_AUTH_ENABLED": {
      "type": "boolean",
      "default": true,
      "description": "Enable MongoDB authentication"
    },
    "LOG_LEVEL": {
      "type": "string",
      "enum": ["debug", "info", "warn", "error"],
      "default": "info",
      "description": "Application log level"
    },
    "ENVIRONMENT_SERVICE_VARIABLES": {
      "type": "object",
      "description": "Service-specific database and connection URLs"
    }
  },
  "additionalProperties": true
}
