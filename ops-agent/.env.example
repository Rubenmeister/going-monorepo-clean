# ─── Google Cloud ─────────────────────────────────────────────
# ID del proyecto en GCP (ej: going-5d1ae)
GCP_PROJECT=going-XXXXXX

# ─── Telegram ─────────────────────────────────────────────────
# Token del bot de Telegram (formato: 123456789:ABCdef...)
# Obtener en @BotFather
TELEGRAM_BOT_TOKEN=

# ID del chat / grupo de operaciones (puede ser negativo para grupos)
# Obtener con @userinfobot o mirando la URL del grupo
TELEGRAM_CHAT_ID=

# ─── Notas de despliegue ──────────────────────────────────────
# Este agente se ejecuta como Cloud Run Job cada 30 minutos.
# Las credenciales de GCP se proveen via Application Default Credentials
# (la cuenta de servicio del Job debe tener rol: Cloud Datastore User).
#
# Para configurar en producción, guardar los valores en GCP Secret Manager:
#   gcloud secrets create TELEGRAM_BOT_TOKEN --data-file=-
#   gcloud secrets create TELEGRAM_CHAT_ID --data-file=-
