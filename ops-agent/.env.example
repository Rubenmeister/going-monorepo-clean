# ─── Google Cloud ─────────────────────────────────────────────
# ID del proyecto en GCP (ej: going-5d1ae)
GCP_PROJECT=going-XXXXXX

# ─── MongoDB Atlas (OBLIGATORIO) ──────────────────────────────
# Cluster compartido con el resto de servicios. El agente lee:
#   going-bookings.rides   (escrito por transport-service)
#   going-users.users      (escrito por user-auth-service)
# Sin esta variable el agente aborta en arranque (process.exit(1)).
MONGO_URL=mongodb+srv://user:pass@cluster.vy28mpj.mongodb.net/?retryWrites=true&w=majority

# Override opcional de los nombres de las DBs (defaults arriba).
# Útil para correr contra un staging cluster sin tocar el código.
# MONGO_DB_RIDES=going-bookings
# MONGO_DB_USERS=going-users

# ─── Telegram ─────────────────────────────────────────────────
# Token del bot de Telegram (formato: 123456789:ABCdef...).
# Obtener en @BotFather.
TELEGRAM_BOT_TOKEN=

# ID del chat / grupo de operaciones (puede ser negativo para grupos).
# Obtener con @userinfobot o mirando la URL del grupo.
TELEGRAM_CHAT_ID=

# ─── Operaciones ──────────────────────────────────────────────
# % de comisión que toma Going sobre el fareTotal — usado en el
# reporte diario para calcular ingreso neto de la plataforma.
GOING_COMMISSION_RATE=0.20

# ─── Cerebro / Pub/Sub publisher ──────────────────────────────
# Cuando true, el agente publica un AgentRunEvent al topic
# `agent.ops.events` al final de cada run. Cuando false (default),
# el agente sigue funcionando como hoy sin tocar Pub/Sub. Habilitar
# solo cuando cerebro-service esté arriba consumiendo.
CEREBRO_PUBLISH_ENABLED=false

# ─── Notas de despliegue ──────────────────────────────────────
# Este agente se ejecuta como Cloud Run Job cada 15 minutos
# (cron */15 * * * * en hora Ecuador, ver cloudbuild.yaml).
# Service Account: going-agent-sa@going-5d1ae.iam.gserviceaccount.com
# Conecta a Atlas vía VPC connector `going-connector` con egress all-traffic.
#
# En producción los valores van a GCP Secret Manager:
#   gcloud secrets create TELEGRAM_BOT_TOKEN --data-file=-
#   gcloud secrets create TELEGRAM_CHAT_ID  --data-file=-
#   gcloud secrets create MONGO_URL-prod    --data-file=-
