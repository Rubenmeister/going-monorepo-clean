# Corporate Portal Environment Variables

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
API_SECRET_KEY=your-secret-key

# Authentication
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3001

# SSO Providers
OKTA_CLIENT_ID=your-okta-client-id
OKTA_CLIENT_SECRET=your-okta-client-secret
OKTA_ISSUER=https://your-domain.okta.com

AZURE_AD_CLIENT_ID=your-azure-client-id
AZURE_AD_CLIENT_SECRET=your-azure-client-secret
AZURE_AD_TENANT_ID=your-tenant-id

GOOGLE_WORKSPACE_CLIENT_ID=your-google-client-id
GOOGLE_WORKSPACE_CLIENT_SECRET=your-google-client-secret
GOOGLE_WORKSPACE_DOMAIN=your-company.com

# Maps (for real-time tracking)
NEXT_PUBLIC_TRACKING_MAP_TOKEN=your-mapbox-token
NEXT_PUBLIC_TRACKING_WS_URL=ws://localhost:4005/corporate-tracking

# Database
MONGODB_URI=mongodb://localhost:27017/going-platform-dev
CORPORATE_DB_URI=mongodb://corporate_service:password@localhost:27017/corporate_db
