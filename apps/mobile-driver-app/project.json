{
  "name": "mobile-driver-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile-driver-app/src",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project mobile-driver-app --web",
  "targets": {
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{workspaceRoot}/coverage/apps/mobile-driver-app"],
      "options": {
        "passWithNoTests": true,
        "reportsDirectory": "../../coverage/apps/mobile-driver-app"
      }
    },
    "build-android": {
      "executor": "@nx/react-native:build-android",
      "outputs": ["{projectRoot}/android/app/build/outputs/apk", "{projectRoot}/android/app/build/outputs/bundle"],
      "options": {}
    },
    "build-ios": {
      "executor": "@nx/react-native:build-ios",
      "outputs": ["{projectRoot}/ios/build"],
      "options": {}
    }
  }
}
