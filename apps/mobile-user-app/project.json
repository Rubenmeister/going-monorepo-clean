{
  "name": "mobile-user-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile-user-app/src",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project mobile-user-app --web",
  "targets": {
    "build-android": {
      "executor": "@nx/react-native:build-android",
      "outputs": ["{projectRoot}/android/app/build/outputs/apk", "{projectRoot}/android/app/build/outputs/bundle"],
      "options": {}
    },
    "build-ios": {
      "executor": "@nx/react-native:build-ios",
      "outputs": ["{projectRoot}/ios/build"],
      "options": {}
    }
  }
}
