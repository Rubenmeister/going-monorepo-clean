# ===== SENTRY CONFIGURATION =====
# Sentry error tracking and performance monitoring DSNs
# Copy this file to .env and fill in your actual Sentry project DSNs

# Main Sentry DSN (used if service-specific DSN not provided)
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Environment: development, staging, production
SENTRY_ENVIRONMENT=production

# Release version (should match package.json version)
SENTRY_RELEASE=1.0.0

# Performance monitoring settings
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ===== SERVICE-SPECIFIC SENTRY DSNs =====

# Core Services
SENTRY_DSN_API_GATEWAY=https://key@sentry.io/project-id
SENTRY_DSN_USER_AUTH=https://key@sentry.io/project-id
SENTRY_DSN_BOOKING=https://key@sentry.io/project-id

# Business Services
SENTRY_DSN_PAYMENT=https://key@sentry.io/project-id
SENTRY_DSN_TRANSPORT=https://key@sentry.io/project-id
SENTRY_DSN_NOTIFICATIONS=https://key@sentry.io/project-id
SENTRY_DSN_TRACKING=https://key@sentry.io/project-id

# Analytics & Reporting
SENTRY_DSN_ANALYTICS=https://key@sentry.io/project-id
SENTRY_DSN_RATINGS=https://key@sentry.io/project-id
SENTRY_DSN_REPORTING=https://key@sentry.io/project-id

# Advanced Features
SENTRY_DSN_VOICE=https://key@sentry.io/project-id
SENTRY_DSN_AR=https://key@sentry.io/project-id
SENTRY_DSN_ML=https://key@sentry.io/project-id
SENTRY_DSN_BLOCKCHAIN=https://key@sentry.io/project-id
SENTRY_DSN_IOT=https://key@sentry.io/project-id

# Admin & Operations
SENTRY_DSN_ADMIN=https://key@sentry.io/project-id
SENTRY_DSN_BILLING=https://key@sentry.io/project-id

# ===== ALERT CONFIGURATIONS =====

# Slack webhook for critical alerts
SENTRY_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# PagerDuty integration key
SENTRY_PAGERDUTY_KEY=integration-key-from-pagerduty

# Email alerts
SENTRY_ALERT_EMAIL=on-call@going-platform.com

# Alert thresholds
SENTRY_ERROR_RATE_THRESHOLD=5
SENTRY_USER_AFFECTED_THRESHOLD=100
SENTRY_P99_LATENCY_THRESHOLD=1000

# ===== OPTIONAL FEATURES =====

# Enable session replays (video recording of errors)
SENTRY_ENABLE_SESSION_REPLAY=true

# Session replay sample rate (0.0 - 1.0)
SENTRY_REPLAY_SAMPLE_RATE=0.1

# Enable user feedback widget
SENTRY_ENABLE_USER_FEEDBACK=true

# Profiling enabled
SENTRY_ENABLE_PROFILING=true

# ===== DEBUGGING (Development only) =====

# Enable debug logging
SENTRY_DEBUG=false

# Log HTTP requests to Sentry
SENTRY_HTTP_DEBUG=false
