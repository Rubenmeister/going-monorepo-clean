# Phase 5: Messaging & Chat System Configuration

# ============================================================
# FIREBASE CLOUD MESSAGING (FCM) - Push Notifications Android
# ============================================================
# Download from: Firebase Console → Project Settings → Service Account
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-service-account@appspot.gserviceaccount.com
FIREBASE_TYPE=service_account
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs

# ============================================================
# APPLE PUSH NOTIFICATION SERVICE (APNS) - iOS
# ============================================================
# Generate from Apple Developer Account
APNS_TEAM_ID=ABC1234567
APNS_KEY_ID=ABC1234567
APNS_BUNDLE_ID=com.going.rider
APNS_KEY_PATH=/path/to/AuthKey_ABC1234567.p8
APNS_ENVIRONMENT=production

# ============================================================
# TWILIO - SMS Notifications
# ============================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================
# SENDGRID - Email Notifications
# ============================================================
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@going.app
SENDGRID_FROM_NAME=Going

# ============================================================
# SOCKET.IO - WebSocket Configuration
# ============================================================
SOCKET_IO_CORS_ORIGIN=http://localhost:3000,https://going.app
SOCKET_IO_CORS_CREDENTIALS=true
SOCKET_IO_PING_INTERVAL=25000
SOCKET_IO_PING_TIMEOUT=5000
SOCKET_IO_RECONNECTION_DELAY=1000
SOCKET_IO_MAX_HTTP_BUFFER_SIZE=1e6

# ============================================================
# REDIS - Caching & Message Queue
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# ============================================================
# BULL - Job Queue Configuration
# ============================================================
BULL_QUEUE_CONCURRENCY=10
BULL_QUEUE_ATTEMPTS=3
BULL_QUEUE_BACKOFF_DELAY=5000
BULL_QUEUE_REMOVE_ON_COMPLETE=true

# ============================================================
# NOTIFICATION SETTINGS
# ============================================================
NOTIFICATION_BATCH_SIZE=500
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY_MS=5000
NOTIFICATION_EXPIRY_DAYS=7

# ============================================================
# CHAT SETTINGS
# ============================================================
CHAT_MESSAGE_EXPIRY_DAYS=30
CHAT_MAX_MESSAGE_LENGTH=2000
CHAT_TYPING_INDICATOR_TIMEOUT_MS=3000
CHAT_RATE_LIMIT_MESSAGES_PER_MINUTE=60

# ============================================================
# RIDE MATCHING SETTINGS
# ============================================================
RIDE_MATCHING_RADIUS_KM=5
RIDE_MATCHING_MAX_RADIUS_KM=25
RIDE_MATCHING_DRIVER_COUNT=5
RIDE_MATCHING_TTL_SECONDS=120
RIDE_MATCHING_MIN_RATING=4.0
RIDE_MATCHING_MIN_ACCEPTANCE_RATE=0.90

# ============================================================
# GOOGLE MAPS API - ETA & Distance Calculation
# ============================================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ============================================================
# SENTRY - Error Tracking
# ============================================================
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=phase-5.0.0

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================
# DATABASE (Already configured in earlier phases)
# ============================================================
MONGODB_URI=mongodb://localhost:27017/going
MONGODB_USER=admin
MONGODB_PASSWORD=password
