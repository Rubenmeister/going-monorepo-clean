# ─── Servidor ──────────────────────────────────────────────────────────────
PORT=3016

# ─── Google Cloud ──────────────────────────────────────────────────────────
GCP_PROJECT=going-5d1ae
GCP_REGION=us-central1

# ─── MongoDB Atlas ─────────────────────────────────────────────────────────
# DB: going-orchestrator (collection: orchestrator_decisions con TTL 90d).
MONGO_URL=mongodb+srv://user:pass@cluster.vy28mpj.mongodb.net/?retryWrites=true&w=majority

# ─── MyCortex source ───────────────────────────────────────────────────────
# URL del mycortex-service. Polling cada 5 min de /mycortex/intentions.
MYCORTEX_URL=https://mycortex-service-780842550857.us-central1.run.app

# ─── Agent bridge target ───────────────────────────────────────────────────
# El agent-bridge-service traduce nuestros comandos a `gcloud run jobs execute`
# o HTTP a services. Ver agent-bridge-service/.env.example.
AGENT_BRIDGE_URL=https://agent-bridge-service-780842550857.us-central1.run.app

# ─── Guards (modo dormant durante observación) ─────────────────────────────
# Cuando false (default), el dispatcher persiste decisiones en estado
# 'dormant' sin tocar el bridge — útil durante la semana de observación
# de MyCortex para validar shape de intenciones sin riesgo de ejecutar
# acciones reales.
ORCHESTRATOR_EXECUTE_ENABLED=false

# Nivel máximo de safety que se ejecuta automáticamente (rollout gradual):
#   0 → ningún Cat (todo dormant aunque EXECUTE_ENABLED=true)
#   1 → solo Cat 1 (info-only, log_anomaly) — empezamos acá
#   2 → Cat 1 + Cat 2 (reversibles: open_ticket, page_operator)
#   3 → todos. Cat 3 sigue requiring Telegram ack (su gate propio)
ORCHESTRATOR_MAX_AUTO_LEVEL=0

# El poll cada 5 min sí está activo por default (lee + persiste, no toca
# nada externo). Para desactivar, setear false.
ORCHESTRATOR_POLL_ENABLED=true

# ─── Telegram (Cat 3 approvals + post-notify) ──────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=-100123456789

# ─── Notas de despliegue ───────────────────────────────────────────────────
# Cloud Run Service min-instances=1 (cron @nestjs/schedule muere con
# scale-to-zero). Costo ~$5/mes adicional aceptable.
#
# Service Account: orchestrator-service-sa@going-5d1ae.iam.gserviceaccount.com
#   roles requeridos:
#     - roles/secretmanager.secretAccessor
#     (NO necesita roles/run.invoker — eso lo tiene el agent-bridge-service)
