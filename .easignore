# ── node_modules everywhere ──────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Root monorepo config ──────────────────────────────────────────────────────
/package.json
/nx.json
/tsconfig.base.json
/.eslintrc*
/.prettierrc*

# ── pnpm files ────────────────────────────────────────────────────────────────
