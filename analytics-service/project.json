{
  "name": "analytics-service",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "analytics-service/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "options": {
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/analytics-service",
        "main": "analytics-service/src/main.ts",
        "tsConfig": "analytics-service/tsconfig.app.json",
        "webpackConfig": "analytics-service/webpack.config.js"
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "analytics-service:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "analytics-service:build:development"
        },
        "production": {
          "buildTarget": "analytics-service:build:production"
        }
      }
    },
    "test": {
      "options": {
        "passWithNoTests": true
      }
    }
  }
}
