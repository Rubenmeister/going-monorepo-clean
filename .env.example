# Going Platform Environment Configuration

# Database
MONGO_URI=mongodb://going_user:going_password@mongodb:27017/going_platform
MONGO_DB_NAME=going_platform

# Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# Stripe Payment
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# API Configuration
API_URL=http://localhost:3000/api
ADMIN_API_URL=http://localhost:3001/api

# Services Ports
TRANSPORT_SERVICE_PORT=3003
PAYMENT_SERVICE_PORT=3004
RATINGS_SERVICE_PORT=3005
ANALYTICS_SERVICE_PORT=3006
CHAT_SERVICE_PORT=3007
GEOLOCATION_SERVICE_PORT=3008

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=going-uploads

# Third-party APIs
GOOGLE_MAPS_API_KEY=your_google_maps_key

# Security
CORS_ORIGIN=http://localhost:3000
SESSION_SECRET=your_session_secret

# Feature Flags
ENABLE_PAYMENT_PROCESSING=true
ENABLE_REAL_TIME_TRACKING=true
ENABLE_ANALYTICS=true

# Performance
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Deployment
DEPLOYMENT_ENVIRONMENT=development
SENTRY_DSN=your_sentry_dsn
