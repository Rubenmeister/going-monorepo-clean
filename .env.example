# PostgreSQL Connection
DATABASE_URL="postgresql://going_user:going_password@localhost:5432/going_monorepo?schema=public"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="1h"

# Environment
NODE_ENV="development"

# Clerk Identity
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Sentry Observability
SENTRY_DSN="https://..."
SENTRY_TRACES_SAMPLE_RATE="1.0"

# Resend Email
RESEND_API_KEY="re_..."

# Twilio SMS
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="your_token"
TWILIO_FROM_NUMBER="+1..."

# Meta WhatsApp
META_WA_PHONE_NUMBER_ID="your_phone_number_id"
META_WA_ACCESS_TOKEN="your_access_token"

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:8081"

# Production example:
# ALLOWED_ORIGINS="https://going.com,https://www.going.com,https://app.going.com,https://admin.going.com"

# ============================================
# Observability - OpenTelemetry / Jaeger
# ============================================
OTEL_ENABLED="false"
OTEL_SERVICE_NAME="going-api"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
LOG_LEVEL="info"

# ============================================
# Service Ports
# ============================================
API_GATEWAY_PORT=3000
USER_AUTH_SERVICE_PORT=3001
PARCEL_SERVICE_PORT=3002
HOST_SERVICE_PORT=3003
EXPERIENCE_SERVICE_PORT=3004
BOOKING_SERVICE_PORT=3005
TRANSPORT_SERVICE_PORT=3006
PAYMENT_SERVICE_PORT=3007
TOURS_SERVICE_PORT=3008
TRACKING_SERVICE_PORT=3009
NOTIFICATIONS_SERVICE_PORT=3010
