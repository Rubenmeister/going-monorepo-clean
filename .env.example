# Going Platform - Environment Configuration
# Copy to .env and update values for your environment
# IMPORTANT: Never commit .env file with real secrets

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
LOG_LEVEL=debug

# ============================================
# SECURITY - JWT & TOKENS (Phase 2)
# ============================================
# CHANGE THESE FOR PRODUCTION!
JWT_SECRET=your_minimum_32_character_secret_key_change_in_production
JWT_EXPIRES_IN=900                    # 15 minutes (access token)
JWT_REFRESH_EXPIRES_IN=604800         # 7 days (refresh token)

# Request Signing (Inter-service authentication - Phase 2)
REQUEST_SIGNING_SECRET=your_minimum_32_character_signing_secret_change_in_production
SERVICE_ID=user-auth-service

# Account Lockout (Phase 2)
ACCOUNT_LOCKOUT_ENABLED=true
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=15

# HTTPS Enforcement (Phase 2)
HTTPS_ENFORCE=true                    # Set to false in development
HTTPS_PORT=443

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# DATABASES
# ============================================
# MongoDB Admin (docker-compose)
MONGO_ADMIN_PASSWORD=change_me_in_production
MONGO_INITDB_ROOT_PASSWORD=change_me_in_production

# Service Database URLs
USER_DB_URL=mongodb://user_service:user_service_pass@localhost:27017/user_db?authSource=admin
PAYMENT_DB_URL=mongodb://payment_service:payment_service_pass@localhost:27017/payment_db?authSource=admin
ACCOMMODATION_DB_URL=mongodb://accommodation_service:accommodation_service_pass@localhost:27017/accommodation_db?authSource=admin
EXPERIENCE_DB_URL=mongodb://experience_service:experience_service_pass@localhost:27017/experience_db?authSource=admin
TOURS_DB_URL=mongodb://tours_service:tours_service_pass@localhost:27017/tours_db?authSource=admin
TRANSPORT_DB_URL=mongodb://transport_service:transport_service_pass@localhost:27017/transport_db?authSource=admin
PARCEL_DB_URL=mongodb://parcel_service:parcel_service_pass@localhost:27017/parcel_db?authSource=admin
NOTIFICATION_DB_URL=mongodb://notification_service:notification_service_pass@localhost:27017/notification_db?authSource=admin
BOOKING_DB_URL=mongodb://booking_service:booking_service_pass@localhost:27017/booking_db?authSource=admin

# ============================================
# REDIS (Caching & Sessions)
# ============================================
REDIS_PASSWORD=change_me_in_production
REDIS_URL=redis://:change_me_in_production@localhost:6379

# ============================================
# EXTERNAL SERVICES
# ============================================
# Stripe Payment Processing
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================
# SERVICE PORTS
# ============================================
# These are set in docker-compose.yml - override here if needed locally
PORT=3000

# ============================================
# AUDIT LOGGING (Phase 3)
# ============================================
AUDIT_ENABLED=true
AUDIT_DB_URL=mongodb://audit_service:audit_service_pass@localhost:27017/audit_db?authSource=admin
AUDIT_RETENTION_DAYS=90           # Default retention (90 days)
AUDIT_RETENTION_AUTH_DAYS=365     # Auth events kept 1 year
AUDIT_RETENTION_PAYMENT_DAYS=365  # Payment events kept 1 year (compliance)
AUDIT_RETENTION_SCHEDULE="0 2 * * *"  # Nightly cleanup at 02:00 AM (cron)

# ============================================
# MONITORING (Optional)
# ============================================
# Enable metrics collection
ENABLE_METRICS=false
# Prometheus metrics endpoint
METRICS_PORT=9090

# ============================================
# DOCKER REGISTRY (for CI/CD)
# ============================================
DOCKER_REGISTRY=docker.io/yourusername
IMAGE_TAG=latest

# ============================================
# KUBERNETES (for deployments)
# ============================================
KUBE_NAMESPACE=going-production
KUBE_CLUSTER=production-cluster

# Notes:
# - All database passwords should be strong (16+ characters, mixed case, numbers, symbols)
# - JWT_SECRET minimum 32 characters
# - Stripe keys are available from your Stripe dashboard
# - Change default passwords for production deployment
