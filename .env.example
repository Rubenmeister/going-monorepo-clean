# ===========================================================================
# GOING MONOREPO - Root Environment Configuration Template
# ===========================================================================
# Copy this file to .env and fill in the values for your environment
# IMPORTANT: Never commit .env files with real secrets to version control
# ===========================================================================

# ---------------------------------------------------------------------------
# Frontend Configuration (Next.js Apps & React Native)
# ---------------------------------------------------------------------------

# API Gateway URL - Used by all frontend API clients
# Development: http://localhost:3000
# Production: https://api.your-domain.com
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Backend Services Configuration
# ---------------------------------------------------------------------------
# Each microservice needs its own MongoDB database and port configuration
# See individual service .env.example files for service-specific configuration

# ---------------------------------------------------------------------------
# Saga / Cross-Service Communication
# ---------------------------------------------------------------------------
# Used by saga orchestrators for inter-service HTTP callbacks
PAYMENT_SERVICE_URL=http://localhost:3001
BOOKING_SERVICE_URL=http://localhost:3010

# ---------------------------------------------------------------------------
# Docker / Production Configuration
# ---------------------------------------------------------------------------
# JWT Secret (shared across all services for token validation)
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Stripe Payment Gateway (for payment-service)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# MongoDB Production Credentials (for docker-compose.prod.yml)
MONGO_USERNAME=admin
MONGO_PASSWORD=change_this_password_in_production

# Redis Production Credentials (for docker-compose.prod.yml)
REDIS_PASSWORD=change_this_redis_password_in_production

# ---------------------------------------------------------------------------
# Development Notes
# ---------------------------------------------------------------------------
# 1. For local development, the default localhost URLs work out of the box
# 2. For production, update NEXT_PUBLIC_API_GATEWAY_URL to point to your deployed API gateway
# 3. Backend services are configured via their individual .env files (see each service folder)
# 4. Frontend apps (admin-dashboard, frontend-webapp) read NEXT_PUBLIC_* vars at build time
# 5. Mobile apps (mobile-user-app, mobile-driver-app) use process.env at runtime
