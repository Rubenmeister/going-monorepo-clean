# ==========================================
# Going Superapp - Environment Configuration
# ==========================================
# Copy this file to .env and fill in the values

# ==========================================
# DATABASE
# ==========================================
DATABASE_URL="postgresql://user:password@localhost:5432/going?schema=public"

# ==========================================
# FIREBASE (Push Notifications + Phone Auth)
# ==========================================
# Create project at: https://console.firebase.google.com/
# Download service account: Project Settings → Service Accounts → Generate New Private Key

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# ==========================================
# EMAIL (Resend)
# ==========================================
# Get API key at: https://resend.com/api-keys

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# WHATSAPP (Meta Business API)
# ==========================================
# Setup at: https://developers.facebook.com/apps/

META_WA_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxx
META_WA_PHONE_NUMBER_ID=123456789012345

# ==========================================
# SMS / OTP (Twilio)
# ==========================================
# Setup at: https://twilio.com

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1234567890

# ==========================================
# PAYMENTS (Kushki)
# ==========================================
# Setup at: https://kushkipagos.com

KUSHKI_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KUSHKI_PRIVATE_MERCHANT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# AUTHENTICATION
# ==========================================
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRATION=7d

# ==========================================
# OBSERVABILITY (Optional)
# ==========================================
SENTRY_DSN=
OTLP_ENDPOINT=

# ==========================================
# API CONFIGURATION
# ==========================================
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000
