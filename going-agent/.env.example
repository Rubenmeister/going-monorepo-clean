# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Cloud ───────────────────────────────────────────────────────────
# El proyecto de GCP donde corren los servicios y Firestore
GCP_PROJECT=going-5d1ae
GCP_REGION=us-central1

# ── Repositorio ────────────────────────────────────────────────────────────
# Ruta absoluta al monorepo. En Cloud Run Job se monta como volumen.
# En local, apuntar al directorio raíz del monorepo.
REPO_PATH=C:/Users/USER1/going-monorepo-clean

# ── Ciclo del agente ───────────────────────────────────────────────────────
# Intervalo entre ciclos en ms (solo relevante en modo continuo local)
# 1800000 = 30 min | 3600000 = 1 hora
AGENT_INTERVAL_MS=1800000
