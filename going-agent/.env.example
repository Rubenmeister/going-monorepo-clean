# ─── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Modelo del agentic loop. Default haiku-4-5 — tool-use intensivo (15
# iteraciones × varias calls por ciclo), Haiku da el mejor balance
# costo/calidad. Para casos donde se necesite mejor razonamiento sobre
# diff (ej. fixes complejos), considerar claude-sonnet-4-5.
AGENT_MODEL=claude-haiku-4-5

# ─── Google Cloud ───────────────────────────────────────────────────────────
GCP_PROJECT=going-5d1ae
GCP_REGION=us-central1

# ─── GitHub (clonar + commit + push del repo) ───────────────────────────────
# OBLIGATORIO — sin esto el agent aborta en arranque.
# Personal Access Token (PAT) con permisos repo:* o GitHub App token.
GIT_TOKEN=ghp_xxx
# URL del repositorio (sin protocolo ni token; el agente arma la URL completa).
REPO_URL=github.com/Rubenmeister/going-monorepo-clean.git
# Path local donde se clona dentro del container (Cloud Run permite /tmp).
REPO_PATH=/tmp/going-repo

# ─── Telegram (reporte de cada ciclo del agente) ────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=-100123456789

# ─── Cerebro / Pub/Sub publisher ────────────────────────────────────────────
# Cuando true, publica AgentRunEvent al topic `agent.going.events` al final
# del ciclo. Default false hasta que cerebro-service esté arriba.
CEREBRO_PUBLISH_ENABLED=false

# ─── Notas de despliegue ────────────────────────────────────────────────────
# Cloud Run Job, schedule cron `0 */6 * * *` (cada 6h, hora UTC).
# Service Account: going-agent-sa@going-5d1ae.iam.gserviceaccount.com
#   roles requeridos:
#     - roles/datastore.user             (Firestore: going_agent_memory)
#     - roles/logging.viewer             (lectura de logs Cloud Run)
#     - roles/cloudbuild.builds.viewer   (lectura de builds)
#     - roles/secretmanager.secretAccessor
#
# El agente NUNCA hace commit a main — solo a la rama `agent/fixes`.
# Blacklist de archivos protegidos está hardcoded en src/config.ts.
