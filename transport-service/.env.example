# Transport Service Environment Variables

PORT=3003
NODE_ENV=development

# MongoDB
TRANSPORT_DB_URL=mongodb://localhost:27017/going_transport

# Redis
REDIS_URL=redis://localhost:6379

# JWT (for verifying tokens from user-auth-service)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Sentry
SENTRY_DSN=your-sentry-dsn

# ── Twilio Proxy (Number Masking conductor ↔ pasajero) ──────────────────────
# Obtener en: https://console.twilio.com
# 1. Crea cuenta Twilio → copia Account SID y Auth Token del Dashboard
# 2. En Console → Proxy → Create a Proxy Service → copia el Service SID (KS...)
# 3. Compra al menos 1 número ecuatoriano o US en Twilio (pool de proxy)
# Si no configuras estas 3 variables, el sistema usa número real como fallback.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PROXY_SERVICE_SID=KSxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── DATAFAST Ecuador (pasarela de pagos) ────────────────────────────────────
# Obtener en: https://developers.datafast.com.ec  /  soporte@datafast.com.ec
#
# PAYMENT_PROVIDER controla qué proveedor se usa:
#   mock      → simulador local, sin credenciales reales (default si no hay credenciales)
#   datafast  → producción / sandbox de DATAFAST
#
# Para sandbox usa DATAFAST_API_URL=https://ccapi-test.datafast.com.ec
# Para producción usa DATAFAST_API_URL=https://ccapi.datafast.com.ec
#
# DATAFAST_MODE controla el modo de integración:
#   redirect   → redirige al usuario a la página de pago de DATAFAST (recomendado, sin PCI)
#   lightbox   → carga el formulario DATAFAST como iframe/modal dentro de la app
#   direct_api → envía datos de tarjeta server-to-server (requiere certificación PCI)

PAYMENT_PROVIDER=mock
APP_BASE_URL=http://localhost:3000

DATAFAST_MERCHANT_ID=tu_merchant_id
DATAFAST_TERMINAL_ID=tu_terminal_id
DATAFAST_API_KEY=tu_api_key
DATAFAST_WEBHOOK_SECRET=tu_webhook_secret
DATAFAST_API_URL=https://ccapi-test.datafast.com.ec
DATAFAST_CHECKOUT_JS_URL=https://ccapi-test.datafast.com.ec/paymentWidgets.js
DATAFAST_MODE=redirect

# ── Agora.io (llamadas in-app conductor↔pasajero) ───────────────────────────
# Obtener en: https://console.agora.io → Project Management → tu proyecto
# 10,000 minutos gratis/mes, luego $0.99/1,000 min
AGORA_APP_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AGORA_APP_CERTIFICATE=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
