# Transport Service Environment Variables

PORT=3003
NODE_ENV=development

# MongoDB
TRANSPORT_DB_URL=mongodb://localhost:27017/going_transport

# Redis
REDIS_URL=redis://localhost:6379

# JWT (for verifying tokens from user-auth-service)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Sentry
SENTRY_DSN=your-sentry-dsn
