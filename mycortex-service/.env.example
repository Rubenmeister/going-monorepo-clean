# ─── Servidor ──────────────────────────────────────────────────────────────
PORT=3015

# ─── Google Cloud ──────────────────────────────────────────────────────────
GCP_PROJECT=going-5d1ae
GCP_REGION=us-central1

# ─── MongoDB Atlas ─────────────────────────────────────────────────────────
# DB: going-mycortex (collection: mycortex_intentions con TTL 30d).
MONGO_URL=mongodb+srv://user:pass@cluster.vy28mpj.mongodb.net/?retryWrites=true&w=majority

# ─── Anthropic Claude ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Default sonnet-4-5 (sweet spot calidad/precio para razonamiento corto).
# Para casos de alto valor o contextos complejos, claude-opus-4-5.
MYCORTEX_MODEL=claude-sonnet-4-5

# ─── Cerebro Service (fuente del world snapshot) ───────────────────────────
# URL del cerebro-service. MyCortex hace HTTP GET /cerebro/state cada 30 min.
CEREBRO_STATE_URL=https://cerebro-service-780842550857.us-central1.run.app

# ─── Reasoning loop guard ──────────────────────────────────────────────────
# Cuando true, el cron @Every30Minutes llama a Claude y propone intenciones.
# Cuando false (default), el cron logea pero no toca Anthropic — útil para
# deploys de prueba sin consumir créditos.
MYCORTEX_REASONING_ENABLED=false

# ─── Telegram (canal donde se reportan las intenciones) ────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=-100123456789

# ─── Notas de despliegue ───────────────────────────────────────────────────
# Cloud Run Service always-on (min-instances=1) para que el cron corra fiable.
# Service Account: mycortex-service-sa@going-5d1ae.iam.gserviceaccount.com
#   roles requeridos:
#     - roles/secretmanager.secretAccessor (para MONGO_URL + ANTHROPIC_API_KEY)
#
# Costo estimado: ~$50-100/mes (1-2 USD por run × 48 runs/día) cuando
# MYCORTEX_REASONING_ENABLED=true. Cero cuando está dormant.
