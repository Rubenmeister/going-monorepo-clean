{
  "name": "going-monorepo-clean",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "storybook:serve": "npx serve storybook-static",
    "test": "jest",
    "test:unit": "jest --testPathPattern='(?<!integration)' --coverage",
    "test:integration": "jest --testPathPattern='integration'",
    "test:all": "jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=lcov",
    "test:payment": "jest payment-service --coverage",
    "test:ratings": "jest ratings-service --coverage",
    "test:analytics": "jest analytics-service --coverage",
    "test:security": "pnpm audit --audit-level=high || true",
    "test:security:strict": "pnpm audit --audit-level=critical",
    "lint": "npx nx affected:lint --head=HEAD --base=main",
    "lint:all": "npx eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:backend": "npx nx run-many -t lint --projects=user-auth-service,transport-service,payment-service,booking-service,tracking-service,notifications-service,envios-service,tours-service,anfitriones-service,experiencias-service,api-gateway,billing-service,analytics-service,customer-support-service,social-service,security-service,ratings-service --parallel",
    "test:backend": "npx nx run-many -t test --projects=user-auth-service,transport-service,payment-service,booking-service,tracking-service,notifications-service,envios-service,tours-service,anfitriones-service,experiencias-service,api-gateway,billing-service,analytics-service,customer-support-service,social-service,security-service,ratings-service --parallel",
    "build:backend": "npx nx run-many -t build --projects=user-auth-service,transport-service,payment-service,booking-service,tracking-service,notifications-service,envios-service,tours-service,anfitriones-service,experiencias-service,api-gateway,billing-service,analytics-service,customer-support-service,social-service,security-service,ratings-service --parallel",
    "lint:web": "npx nx run-many -t lint --projects=frontend-webapp,admin-dashboard,website --parallel",
    "test:web": "npx nx run-many -t test --projects=frontend-webapp,admin-dashboard,website --parallel",
    "build:web": "npx nx run-many -t build --projects=frontend-webapp,admin-dashboard,website --parallel",
    "lint:mobile": "npx nx run-many -t lint --projects=mobile-user-app,mobile-driver-app --parallel",
    "test:mobile": "npx nx run-many -t test --projects=mobile-user-app,mobile-driver-app --parallel",
    "build:mobile": "npx nx run-many -t build --projects=mobile-user-app,mobile-driver-app --parallel",
    "validate:backend": "pnpm run lint:backend && pnpm run test:backend && pnpm run build:backend",
    "validate:web": "pnpm run lint:web && pnpm run test:web && pnpm run build:web",
    "validate:full": "pnpm run validate:backend && pnpm run validate:web && pnpm run validate:mobile",
    "validate:mobile": "pnpm run lint:mobile && pnpm run test:mobile",
    "dev:webapp": "npx nx serve frontend-webapp",
    "build:webapp": "npx nx build frontend-webapp",
    "start:webapp": "npx nx serve frontend-webapp --configuration=production",
    "lint:webapp": "npx nx lint frontend-webapp",
    "dev:admin": "npx nx serve admin-dashboard",
    "build:admin": "npx nx build admin-dashboard",
    "dev:all": "pnpm run dev:webapp & pnpm run dev:admin",
    "build:all": "pnpm run build:webapp && pnpm run build:admin",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:chrome": "cypress run --browser chrome",
    "cypress:ci": "cypress run --headless --browser chromium",
    "dev:mobile:user": "npx nx serve mobile-user-app",
    "dev:mobile:driver": "npx nx serve mobile-driver-app",
    "dev:mobile:user:web": "cd mobile-user-app && pnpm run web",
    "dev:mobile:driver:web": "cd mobile-driver-app && pnpm run web",
    "mobile:user:android": "cd mobile-user-app && pnpm run android",
    "mobile:user:ios": "cd mobile-user-app && pnpm run ios",
    "mobile:driver:android": "cd mobile-driver-app && pnpm run android",
    "mobile:driver:ios": "cd mobile-driver-app && pnpm run ios",
    "install:all": "pnpm install",
    "setup:design": "bash setup-design-system.sh",
    "dev:quick": "pnpm run dev:webapp",
    "dev:full": "pnpm run dev:webapp & pnpm run dev:admin & pnpm run dev:mobile:user:web",
    "test:e2e": "cypress run --headless",
    "test:e2e:watch": "cypress open",
    "test:e2e:passenger": "cypress run --spec 'cypress/e2e/passenger-complete-ride.cy.ts'",
    "test:e2e:driver": "cypress run --spec 'cypress/e2e/driver-accept-complete-ride.cy.ts'",
    "test:e2e:admin": "cypress run --spec 'cypress/e2e/admin-dashboard.cy.ts'",
    "test:e2e:all": "cypress run",
    "test:e2e:ci": "cypress run --headless --browser chromium --record false",
    "load:test": "k6 run __tests__/load/ride-load-test.js",
    "load:test:peak": "k6 run __tests__/load/peak-hours-load-test.js",
    "load:test:report": "k6 run __tests__/load/ride-load-test.js --out json=load-test-results.json",
    "build:production": "pnpm run build:all",
    "serve:production": "pnpm run start:webapp",
    "clean": "rm -rf .next dist node_modules mobile-user-app/node_modules mobile-driver-app/node_modules .cache",
    "clean:install": "pnpm run clean && pnpm install",
    "dev": "pnpm run dev:webapp"
  },
