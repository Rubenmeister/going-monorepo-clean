# ─── Anthropic Claude ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Modelo para insights del reporte semanal (~400 tokens output, low volumen).
AI_INSIGHTS_MODEL=claude-sonnet-4-5

# Modelo para generación creativa de contenido (captions, newsletters, press
# releases). Default sonnet-4-5; para alto volumen futuro considerar Haiku
# o migrar a Gemini Flash (ya validado en customer-support y financial).
AI_CONTENT_MODEL=claude-sonnet-4-5

# ─── Google Cloud ──────────────────────────────────────────────────────────
GCP_PROJECT=going-5d1ae
GCP_REGION=us-central1

# ─── Telegram (canal público + chat ops) ───────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAF...
# Canal público @goingappecuador donde se publican posts (número negativo).
TELEGRAM_CHANNEL_ID=-100123456789
# Chat privado de operaciones para alertas + reporte semanal.
TELEGRAM_CHAT_ID=-100987654321

# ─── Meta (Facebook + Instagram) ───────────────────────────────────────────
META_ACCESS_TOKEN=EAAxxxx...
META_PAGE_ID=123456789            # ID de página Facebook (goingappecuador)
META_IG_USER_ID=987654321         # ID Business Account de Instagram

# ─── Meta WhatsApp Business ────────────────────────────────────────────────
# Usado para métricas de mensajes (sent/delivered/read).
META_WA_ACCESS_TOKEN=EAAxxxx...
WHATSAPP_BUSINESS_ACCOUNT_ID=...

# ─── X / Twitter (@GoingAppecuador) ────────────────────────────────────────
TWITTER_API_KEY=xxxx
TWITTER_API_SECRET=xxxx
TWITTER_ACCESS_TOKEN=xxxx-xxxx
TWITTER_ACCESS_SECRET=xxxx
# Bearer token para lectura de métricas públicas (app-only auth).
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAxxxx...

# ─── TikTok (@goingappecuador) ─────────────────────────────────────────────
TIKTOK_ACCESS_TOKEN=xxxx...       # TikTok for Business Content Posting API

# ─── YouTube (@Goingappecuador) ────────────────────────────────────────────
YOUTUBE_API_KEY=AIza...
YOUTUBE_CHANNEL_ID=UCxxxx...

# ─── LinkedIn (company/going-app) ──────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=AQVxxxx...
LINKEDIN_ORG_ID=12345678          # Organization ID

# ─── Meta Threads (@goingappecuador) ───────────────────────────────────────
THREADS_ACCESS_TOKEN=THAxxxx...
THREADS_USER_ID=12345678

# ─── SendGrid (email campaigns, futuro) ────────────────────────────────────
SENDGRID_API_KEY=SG.xxxx...

# ─── Cerebro / Pub/Sub publisher ───────────────────────────────────────────
# Cuando true, publica AgentRunEvent al topic `agent.marketing.events`.
# Default false hasta que cerebro-service esté arriba consumiendo.
CEREBRO_PUBLISH_ENABLED=false

# ─── Modos de prueba ───────────────────────────────────────────────────────
# Forzar el reporte semanal sin esperar al lunes 9am.
# FORCE_WEEKLY_REPORT=1

# ─── Notas de despliegue ───────────────────────────────────────────────────
# Cloud Run Job, schedule cron `0 9 * * 1` (lunes 9am Ecuador).
# Service Account: going-agent-sa@going-5d1ae.iam.gserviceaccount.com
#   roles requeridos:
#     - roles/datastore.user             (Firestore: marketing_agent_state)
#     - roles/secretmanager.secretAccessor
#
# Plataformas con secret faltante fallan silenciosamente — el reporte sale
# con las que sí tienen token. Esto facilita habilitarlas progresivamente.
