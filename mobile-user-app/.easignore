# EAS upload exclusions — mantener el archive bajo 2 GB.
# Sintaxis estilo .gitignore. Paths relativos a mobile-user-app/.

# === Web/Next.js artifacts dentro de mobile-user-app ===
.next/
.expo/
.cache/
public/
index.html
next.config.js
next-env.d.ts

# === Build artifacts ===
node_modules/
ios/Pods/
ios/build/
android/build/
android/.gradle/
android/app/build/
android/.idea/

# === Logs & test ===
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
__tests__/
coverage/
.nyc_output/

# === Slideshow/preview HTML que no van al APK ===
driver-screens-preview.html
driver-screens-slideshow.html

# === Assets pesados no referenciados — whitelist abajo ===
# Audit 2026-05-28: 30 PNGs numerados (10.png-58.png) + algunos otros
# pesan ~200 MB pero NO están referenciados en src/. Excluimos TODOS los
# PNG/JPG de assets/ y después white-listamos los 15 que sí se usan.
# Si vas a agregar un asset nuevo, agregalo a la whitelist abajo.

assets/*.png
assets/*.jpg
assets/*.jpeg
assets/*.JPG
assets/*.JPEG

# Whitelist — assets REALMENTE referenciados en src/:
!assets/1. uv.jpg
!assets/2.suvxl.jpg
!assets/3van.jpg
!assets/4.VAN XL.jpg
!assets/5. bus grande y pequeño.png
!assets/6. bus.png
!assets/entrega.png
!assets/going-logo-envios.png
!assets/going-logo-horizontal-white.png
!assets/going-logo-horizontal.png
!assets/going-logo-splash.png
!assets/going-logo-white.png
!assets/going-logo.png
!assets/splash-bg.png
!assets/suv premium.jpg
# Iconos de la app (referenciados en app.json):
!assets/icon.png
!assets/adaptive-icon.png
!assets/splash.png
!assets/favicon.png
!assets/notification-icon.png
!assets/icon-512.png
!assets/feature-graphic.jpg

