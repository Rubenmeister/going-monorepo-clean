{
  "name": "ratings-service",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "ratings-service/src",
  "projectType": "application",
  "tags": ["type:service", "scope:backend"],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "options": {
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/ratings-service",
        "main": "ratings-service/src/main.ts",
        "tsConfig": "ratings-service/tsconfig.app.json",
        "webpackConfig": "ratings-service/webpack.config.js"
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "ratings-service:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "ratings-service:build:development"
        },
        "production": {
          "buildTarget": "ratings-service:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["ratings-service/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "ratings-service/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
