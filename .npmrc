# pnpm is the only package manager allowed in this monorepo
shamefully-hoist=false
strict-peer-dependencies=false
auto-install-peers=true
engine-strict=false

# Ensure reproducible builds
lockfile-only=false

# Node modules resolution
dedupe-peer-dependents=true

# npm (Vercel) — tolerar peer-deps mismatches (cache-manager v5 vs @nestjs/cache-manager v3)
legacy-peer-deps=true
