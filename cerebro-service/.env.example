# ─── Servidor ──────────────────────────────────────────────────────────────
PORT=3014

# ─── Google Cloud ──────────────────────────────────────────────────────────
GCP_PROJECT=going-5d1ae
GCP_REGION=us-central1

# ─── MongoDB Atlas ─────────────────────────────────────────────────────────
# DB: going-cerebro (collections: cerebro_agent_events, cerebro_world_snapshots)
# Mismo cluster que el resto, DB separada para no mezclar telemetría con
# datos del producto.
MONGO_URL=mongodb+srv://user:pass@cluster.vy28mpj.mongodb.net/?retryWrites=true&w=majority

# ─── Pub/Sub Subscriber ────────────────────────────────────────────────────
# Cuando true, el service consume las 6 subscriptions cerebro-agent.<x>.events.
# Cuando false, el service arranca pero no toca Pub/Sub — útil para deploys
# de prueba sin procesar eventos reales (los eventos quedan en cola hasta
# que se active).
CEREBRO_SUBSCRIBE_ENABLED=true

# ─── World Model (Fase 2) ──────────────────────────────────────────────────
# Ventana hacia atrás (en minutos) que WorldModelService considera para
# tomar como "vigentes" las anomalías + acciones propuestas de cada agente.
# Default 30 min — cubre el cron de los agentes más rápidos (ops c/15 min);
# los semanales (content/marketing) aparecen "stale" si corren hace días,
# lo cual es correcto.
WORLD_MODEL_WINDOW_MIN=30

# Cron del snapshot del WorldModelService está hardcoded a cada 10 min
# (alineado con customer-support publisher). Cambiar la frecuencia requiere
# editar @Cron en world-model.service.ts.

# ─── Notas de despliegue ───────────────────────────────────────────────────
# Cloud Run Service (always-on para consumir Pub/Sub continuamente).
# Service Account: cerebro-service-sa@going-5d1ae.iam.gserviceaccount.com
#   roles requeridos:
#     - roles/pubsub.subscriber  (sobre cada cerebro-agent.<x>.events sub)
#     - roles/secretmanager.secretAccessor  (para MONGO_URL)
#
# El SA y los IAM bindings los provisiona scripts/cerebro/bootstrap-pubsub.sh.
