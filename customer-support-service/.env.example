# ── Servidor ───────────────────────────────────────────────────────────────
PORT=3013

# ── Google Cloud ───────────────────────────────────────────────────────────
# El LLM corre sobre Vertex AI (Gemini 2.5 Flash) — ver agent.service.ts.
# Las credenciales se obtienen del service account asociado al servicio
# Cloud Run (going-agent-sa@going-5d1ae.iam.gserviceaccount.com).
GCP_PROJECT=going-5d1ae
GCP_REGION=us-central1

# ── MongoDB Atlas ──────────────────────────────────────────────────────────
# DB: going-support (collection: conversations)
MONGO_URL=mongodb+srv://user:pass@cluster.vy28mpj.mongodb.net/?retryWrites=true&w=majority

# ── JWT (debe coincidir con el secret usado en transport-service) ───────────
# ⚠️  OBLIGATORIO — sin esto los viajes creados desde WhatsApp serán rechazados
JWT_SECRET=un-secret-seguro-de-al-menos-32-caracteres

# ── Transport Service (internal URL en Cloud Run) ──────────────────────────
TRANSPORT_SERVICE_URL=https://transport-service-780842550857.us-central1.run.app

# ── WhatsApp / Meta Cloud API ──────────────────────────────────────────────
# Único proveedor de WhatsApp (inbound + outbound). Twilio quedó deprecado
# para este servicio — los recordatorios de viaje también salen por Meta.
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345
META_WA_ACCESS_TOKEN=EAA...  # System User token, never-expires
WHATSAPP_VERIFY_TOKEN=going_webhook_verify_2024

# ── Telegram Bot ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AA...
TELEGRAM_WEBHOOK_SECRET=optional-shared-secret-with-meta-setwebhook
# Comma-separated chat IDs de operadores que reciben handoffs y pueden usar /queue, /take, /reply, /resolve
OPERATOR_TELEGRAM_CHAT_IDS=123456789,987654321

# ── Mapbox (geocodificación de direcciones) ────────────────────────────────
MAPBOX_TOKEN=pk.eyJ1Ijoixxxxxxxx...

# ── Cerebro / Pub/Sub publisher ────────────────────────────────────────────
# Cuando true, el CerebroPublisherService publica un AgentRunEvent al topic
# `agent.customer-support.events` cada 10 min con métricas agregadas:
# conversaciones activas, handoffs pendientes por priority, edad del
# RED/ORANGE más viejo, ventana 10 min de actividad, etc.
#
# Default false hasta que cerebro-service esté arriba consumiendo.
CEREBRO_PUBLISH_ENABLED=false
