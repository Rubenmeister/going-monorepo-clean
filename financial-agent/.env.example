# ─── Google Cloud ──────────────────────────────────────────────────────────
GCP_PROJECT=going-5d1ae
GCP_REGION=us-central1

# ─── MongoDB Atlas (OBLIGATORIO) ───────────────────────────────────────────
# Cluster compartido. El agente lee:
#   going-bookings.rides     (transport-service)
#   going-users.users        (user-auth-service)
# Sin esto el agente aborta en arranque.
MONGO_URL=mongodb+srv://user:pass@cluster.vy28mpj.mongodb.net/?retryWrites=true&w=majority

# ─── AI (Vertex AI / Gemini 2.5 Flash) ─────────────────────────────────────
# Auth: Application Default Credentials del SA going-agent-sa (no API key).
# Modelo override opcional — default gemini-2.5-flash (~40x más barato que
# Claude Sonnet para outputs cortos del análisis financiero).
AI_ANALYSIS_MODEL=gemini-2.5-flash

# ─── Gmail (alertas financieras por email HTML) ────────────────────────────
GMAIL_FROM=goingappecuador@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
NOTIFICATION_EMAIL=goingappecuador@gmail.com

# ─── Datil (facturación electrónica SRI Ecuador) ───────────────────────────
DATIL_API_KEY=tu_api_key_de_datil
# Ambiente: 1 = pruebas (SRI test) | 2 = producción (SRI real)
# ⚠️  USAR "1" hasta tener RUC y perfil Datil validados en producción
DATIL_ENV=1
DATIL_CERT_PASSWORD=

# ─── Going Ecuador (emisor de facturas) ────────────────────────────────────
# RUC de la empresa (13 dígitos). OBLIGATORIO — sin esto las facturas son inválidas.
GOING_RUC=1792XXXXXXX001
GOING_ADDRESS=Av. República de El Salvador N35-88, Torre Atiria Piso 10, Quito

# ─── Cerebro / Pub/Sub publisher ───────────────────────────────────────────
# Cuando true, el agente publica un AgentRunEvent al topic
# `agent.financial.events` al final de cada run. Cuando false (default),
# el agente sigue funcionando como hoy sin tocar Pub/Sub. Habilitar
# solo cuando cerebro-service esté arriba consumiendo.
CEREBRO_PUBLISH_ENABLED=false

# ─── Modos de prueba (deshabilitados en producción) ────────────────────────
# Inserta un ride sintético, deja que el loop lo facture, limpia al final.
# Solo útil para verificar Datil sin esperar a viajes reales.
# TEST_SEED=1
# Forzar payouts semanales o conciliación sin esperar al horario.
# FORCE_WEEKLY_PAYOUTS=1
# FORCE_RECONCILIATION=1

# ─── Notas de despliegue ───────────────────────────────────────────────────
# Cloud Run Job, schedule cron `0 8,9,12,20 * * *` hora Ecuador.
# Service Account: going-agent-sa@going-5d1ae.iam.gserviceaccount.com
#   roles requeridos:
#     - roles/aiplatform.user        (Vertex AI / Gemini)
#     - roles/datastore.user         (Firestore)
#     - roles/secretmanager.secretAccessor
# Conecta a Atlas vía VPC connector `going-connector` con egress all-traffic.
