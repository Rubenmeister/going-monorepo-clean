{
  "name": "going-kb",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/going-kb/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/going-kb",
        "main": "libs/going-kb/src/index.ts",
        "tsConfig": "libs/going-kb/tsconfig.lib.json",
        "assets": ["libs/going-kb/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/going-kb"],
      "options": {
        "jestConfig": "libs/going-kb/jest.config.cts",
        "passWithNoTests": true
      }
    }
  }
}
