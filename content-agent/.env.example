# ─── Google Cloud ──────────────────────────────────────────────────────────
GCP_PROJECT=going-5d1ae

# ─── Anthropic Claude (generación del tip semanal público) ─────────────────
# El tip representa la marca pública de Going — usamos Claude por calidad
# de copywriting en español ecuatoriano. Volumen mínimo (~52 tips/año).
# Para cualquier futuro caso de alto volumen, considerar Gemini Flash.
ANTHROPIC_API_KEY=sk-ant-...
AI_TIP_MODEL=claude-sonnet-4-5

# ─── Gmail (alertas internas a ops) ────────────────────────────────────────
GMAIL_FROM=goingappecuador@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
NOTIFICATION_EMAIL=rubenmeister@gmail.com

# ─── Telegram público (canal de tips de Going) ─────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAF...
# Chat ID del canal/grupo donde se publica el tip semanal.
# Si está vacío, cae a TELEGRAM_CHAT_ID (chat de operaciones, default).
CONTENT_TELEGRAM_CHAT_ID=
TELEGRAM_CHAT_ID=-100123456789

# ─── Modos de prueba ───────────────────────────────────────────────────────
# Forzar la generación + publicación del tip semanal sin esperar al lunes 9am.
# FORCE_WEEKLY_TIP=1

# ─── Notas de despliegue ───────────────────────────────────────────────────
# Cloud Run Job, schedule cron `0 9 * * 1` (lunes 9am Ecuador).
# Service Account: going-agent-sa@going-5d1ae.iam.gserviceaccount.com
#   roles requeridos:
#     - roles/datastore.user             (Firestore)
#     - roles/secretmanager.secretAccessor
